{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "skipLibCheck": true,
    "paths": {
      "@go-go-golems/os-shell": ["../../../go-go-os-frontend/packages/os-shell/src"],
      "@go-go-golems/os-shell/*": ["../../../go-go-os-frontend/packages/os-shell/src/*"],
      "@go-go-golems/os-core": ["../../../go-go-os-frontend/packages/os-core/src"],
      "@go-go-golems/os-core/*": ["../../../go-go-os-frontend/packages/os-core/src/*"],
      "@go-go-golems/os-scripting": ["../../../go-go-os-frontend/packages/os-scripting/src"],
      "@go-go-golems/os-scripting/*": ["../../../go-go-os-frontend/packages/os-scripting/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/test/**"],
  "references": [
    { "path": "../../../go-go-os-frontend/packages/os-shell" },
    { "path": "../../../go-go-os-frontend/packages/os-core" },
    { "path": "../../../go-go-os-frontend/packages/os-scripting" }
  ]
}
