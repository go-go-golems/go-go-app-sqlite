{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "skipLibCheck": true,
    "paths": {
      "@hypercard/desktop-os": ["../../../go-go-os-frontend/packages/desktop-os/src"],
      "@hypercard/desktop-os/*": ["../../../go-go-os-frontend/packages/desktop-os/src/*"],
      "@hypercard/engine": ["../../../go-go-os-frontend/packages/engine/src"],
      "@hypercard/engine/*": ["../../../go-go-os-frontend/packages/engine/src/*"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../../../go-go-os-frontend/packages/desktop-os" },
    { "path": "../../../go-go-os-frontend/packages/engine" }
  ]
}
